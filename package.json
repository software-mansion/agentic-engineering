{
  "name": "@software-mansion/ai",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "check-external-links": "bun run scripts/check-external-links.ts",
    "check": "prettier --check . && astro check && bun links --check && bun mailmap --check && bun last-revised --check",
    "dev": "astro dev",
    "lint": "prettier --write . && astro check && bun links && bun mailmap && bun last-revised",
    "last-revised": "bun run scripts/last-revised.ts",
    "links": "bun run scripts/links.ts",
    "mailmap": "bun run scripts/mailmap.ts",
    "preview": "astro preview",
    "start": "astro dev"
  },
  "dependencies": {
    "@astrojs/starlight": "0.41.3",
    "@astrojs/starlight-docsearch": "^0.7.0",
    "@std/csv": "npm:@jsr/std__csv@1.0.6",
    "astro": "7.0.7",
    "execa": "9.6.1",
    "sharp": "0.35.3",
    "starlight-llms-txt": "0.11.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@types/bun": "1.3.14",
    "prettier": "3.9.4",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "6.0.3"
  }
