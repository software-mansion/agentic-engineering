---
export interface Props {
  slug: string;
}

const { slug } = Astro.props;
---

<div class="clap-wrapper" data-slug={slug}>
  <div class="clap-ring">
    <button
      class="clap-button"
      aria-label="Clap for this content"
      aria-pressed="false"
    >
      <span class="clap-icon" aria-hidden="true">👏</span>
      <span class="clap-plus" aria-hidden="true">+1</span>
    </button>
  </div>

  <span class="clap-count" aria-live="polite">…</span>
</div>

<script>
  import { z } from "astro/zod";

  const ClapsBatchResponse = z.object({
    max_claps: z.number().int().positive(),
    items: z.array(
      z.object({
        slug: z.string(),
        count: z.number().int().nonnegative(),
        user_claps: z.number().int().nonnegative(),
      }),
    ),
  });

  const API = import.meta.env.PUBLIC_API_URL;

  const wrappers = Array.from(
    document.querySelectorAll<HTMLDivElement>(".clap-wrapper"),
  );

  if (API && wrappers.length > 0) {
    const batchUrl = new URL("/claps/batch", API);
    const updates = new Map<
      string,
      (maxClaps: number, remote: { count: number; user_claps: number }) => void
    >();
    const senders: (() => void)[] = [];

    window.addEventListener("pagehide", () => {
      for (const send of senders) send();
    });
    document.addEventListener("visibilitychange", () => {
      if (document.visibilityState !== "hidden") return;
      for (const send of senders) send();
    });

    for (const wrapper of wrappers) {
      const slug = wrapper.dataset.slug!;
      batchUrl.searchParams.append("slugs", slug);
      const { update, sendClaps } = initButton(API, wrapper, slug);
      updates.set(slug, update);
      senders.push(sendClaps);
    }

    void fetch(batchUrl)
      .then((response) => response.json())
      .then((data: unknown) => {
        const parsing = ClapsBatchResponse.safeParse(data);

        if (!parsing.success) {
          console.error("[ClapButton] Batch parse failed", parsing.error);
          return;
        }

        const { max_claps, items } = parsing.data;
        const bySlug = new Map(items.map((item) => [item.slug, item]));

        for (const wrapper of wrappers) {
          const slug = wrapper.dataset.slug!;
          const item = bySlug.get(slug);

          updates.get(slug)!(max_claps, {
            count: item?.count ?? 0,
            user_claps: item?.user_claps ?? 0,
          });
        }
      })
      .catch((err) => {
        console.error("[ClapButton] Batch fetch failed", err);
      });
  }

  function initButton(
    api: string,
    wrapperElement: HTMLDivElement,
    slug: string,
  ) {
    const buttonElement =
      wrapperElement.querySelector<HTMLButtonElement>(".clap-button")!;
    const countElement =
      wrapperElement.querySelector<HTMLElement>(".clap-count")!;

    const local = { claps: 0, sentClaps: 0 };
    const remote = { count: 0, user_claps: 0 };
    let maxClaps = Number.MAX_SAFE_INTEGER;
    let loaded = false;

    function render() {
      const localClaps = local.claps + remote.user_claps;

      const wasPressed = localClaps > 0;
      const isDisabled = loaded && localClaps >= maxClaps;

      if (loaded) {
        countElement.textContent = String(remote.count);
        wrapperElement.style.setProperty(
          "--clap-progress",
          String(localClaps / maxClaps),
        );
      }
      buttonElement.setAttribute("aria-pressed", String(wasPressed));
      buttonElement.toggleAttribute("disabled", isDisabled);
    }

    function animateClap() {
      buttonElement.classList.remove("clap-pop");
      // Reading offsetWidth forces a reflow, resetting the animation so it replays on every click.
      void buttonElement.offsetWidth;
      buttonElement.classList.add("clap-pop");
    }

    buttonElement.addEventListener("click", () => {
      if (loaded && remote.user_claps + local.claps >= maxClaps) {
        return;
      }

      local.claps++;
      // Optimistic UI Update — keeps the displayed count in sync without a round-trip.
      remote.count++;

      animateClap();
      render();
    });

    const clapsUrl = new URL("/claps", api);
    clapsUrl.searchParams.set("slug", slug);

    function sendClaps() {
      const toSend = local.claps - local.sentClaps;

      if (toSend <= 0) {
        return;
      }

      local.sentClaps = local.claps;
      navigator.sendBeacon(clapsUrl, JSON.stringify({ claps: toSend }));
    }

    function update(
      newMaxClaps: number,
      newRemote: { count: number; user_claps: number },
    ) {
      loaded = true;
      maxClaps = newMaxClaps;
      // Merge real server count with optimistic local claps accumulated before batch returned.
      remote.count = newRemote.count + local.claps;
      remote.user_claps = newRemote.user_claps;
      render();
    }

    return { update, sendClaps };
  }
</script>

<style>
  @layer starlight.core {
    .clap-wrapper {
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      gap: 0.4rem;
    }

    .clap-ring {
      width: 3.5rem;
      height: 3.5rem;
      border-radius: 50%;
      padding: 3px;
      background: conic-gradient(
        var(--sl-color-text-accent) calc(var(--clap-progress, 0) * 360deg),
        var(--sl-color-hairline) 0deg
      );
      transition: background 0.2s;
    }

    .clap-button {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      height: 100%;
      border-radius: 50%;
      border: none;
      background: var(--sl-color-bg);
      cursor: pointer;
      overflow: visible;
      transition: background 0.15s;

      &:hover:not(:disabled) {
        background: color-mix(
          in srgb,
          var(--sl-color-bg),
          var(--sl-color-text-accent) 8%
        );
      }

      &:disabled {
        cursor: not-allowed;
      }

      &:not(:disabled) .clap-icon {
        filter: grayscale(0);
      }

      &.clap-pop .clap-icon {
        animation: clap-pop 0.45s cubic-bezier(0.36, 0.07, 0.19, 0.97) forwards;
      }

      &.clap-pop .clap-plus {
        animation: clap-plus-float 0.55s ease-out forwards;
      }
    }

    .clap-icon {
      font-size: 1.4rem;
      line-height: 1;
      display: block;
      filter: grayscale(0.4);
      transition: filter 0.2s;
    }

    .clap-plus {
      position: absolute;
      top: -0.25rem;
      left: 50%;
      transform: translateX(-50%);
      font-size: 0.7rem;
      font-weight: 700;
      color: var(--sl-color-text-accent);
      pointer-events: none;
      opacity: 0;
      white-space: nowrap;
    }

    .clap-count {
      font-size: var(--sl-text-sm);
      color: var(--sl-color-gray-3);
      min-width: 2ch;
      text-align: center;
      font-variant-numeric: tabular-nums;
    }

    @keyframes clap-pop {
      0% {
        transform: scale(1) rotate(0deg);
      }

      25% {
        transform: scale(1.35) rotate(-14deg);
      }

      55% {
        transform: scale(0.9) rotate(5deg);
      }

      75% {
        transform: scale(1.08) rotate(-3deg);
      }

      100% {
        transform: scale(1) rotate(0deg);
      }
    }

    @keyframes clap-plus-float {
      0% {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
      }

      20% {
        opacity: 1;
      }

      100% {
        opacity: 0;
        transform: translateX(-50%) translateY(-1.75rem);
      }
    }
  }
</style>
